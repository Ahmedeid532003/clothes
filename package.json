{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host=0.0.0.0 --port=8787 --strictPort",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/run-local.ps1",
    "dev:local": "cmd /c scripts\\start-local-api.cmd",
    "dev:cloud": "powershell -ExecutionPolicy Bypass -File scripts/run-local.ps1 -Cloud",
    "dev:online": "powershell -ExecutionPolicy Bypass -File scripts/run-online.ps1",
    "build": "vite build",
    "build:netlify": "vite build --mode production",
    "build:cloudflare": "vite build --mode production",
    "deploy:cloudflare": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloudflare.ps1",
    "deploy:netlify": "powershell -ExecutionPolicy Bypass -File scripts/netlify-cli-deploy.ps1",
    "pack:netlify": "powershell -ExecutionPolicy Bypass -File scripts/pack-netlify-upload.ps1",
    "pack:cloudflare": "powershell -ExecutionPolicy Bypass -File scripts/pack-cloudflare-pages.ps1",
    "pack:vps": "powershell -ExecutionPolicy Bypass -File scripts/pack-vps-upload.ps1",
    "fly:secrets": "powershell -ExecutionPolicy Bypass -File scripts/fly-secrets.ps1",
    "deploy:fly": "powershell -ExecutionPolicy Bypass -File scripts/fly-deploy.ps1",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/cairo": "^5.2.7",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
