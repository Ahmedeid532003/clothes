# Fly.io secrets — set once:
#   flyctl secrets set -a mahalyerp-api DATABASE_URL="postgresql://..." SECRET_KEY="..." ...
#
# Required:
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
SECRET_KEY=change-to-random-long-string-min-50-chars
CLOUD_SHARED_DB=true
DEBUG=false
USE_REDIS=false
DEPLOY_GATE_ENABLED=false
#
# After Cloudflare Pages deploy, add your frontend URL:
# CORS_ALLOWED_ORIGINS=https://YOUR-SITE.pages.dev
# CSRF_TRUSTED_ORIGINS=https://YOUR-SITE.pages.dev
