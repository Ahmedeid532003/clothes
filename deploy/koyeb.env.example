# Koyeb Environment Variables — انسخ هذه في لوحة Koyeb

DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-plain-firefly-atpjb8f6-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

SECRET_KEY=change-to-random-long-string
DEBUG=false
ALLOWED_HOSTS={{ KOYEB_PUBLIC_DOMAIN }}
KOYEB_PUBLIC_DOMAIN={{ KOYEB_PUBLIC_DOMAIN }}
CLOUD_SHARED_DB=true
USE_REDIS=false
DEPLOY_GATE_ENABLED=false

# بعد نشر Netlify — أضف رابط موقعك:
# CORS_ALLOWED_ORIGINS=https://YOUR-SITE.netlify.app
# CSRF_TRUSTED_ORIGINS=https://YOUR-SITE.netlify.app
