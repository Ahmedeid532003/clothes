# Runsite — Secrets tab (مشروع clothes → mahalyerp-api)
# Domain: Settings → Domain → انسخ subdomain (مثال: mahalyerp-api.runsite.app)
# Build: Dockerfile في جذر المستودع | Port: 8080

DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-plain-firefly-atpjb8f6-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require
CLOUD_SHARED_DB=true

SECRET_KEY=change-to-random-long-string-min-50-chars
DEBUG=false
ALLOWED_HOSTS=mahalyerp-api.runsite.app
PORT=8080
WEB_CONCURRENCY=1

USE_REDIS=false
DEPLOY_GATE_ENABLED=false

# بعد نشر الفرونت (Cloudflare Pages أو Netlify):
# CORS_ALLOWED_ORIGINS=https://YOUR-SITE.pages.dev
# CSRF_TRUSTED_ORIGINS=https://YOUR-SITE.pages.dev
